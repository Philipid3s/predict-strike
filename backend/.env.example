# Backend service environment variables.
# Copy to backend/.env and adjust for your chosen stack.

APP_ENV=development
APP_PORT=8000
API_BASE_PATH=/api
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost,http://127.0.0.1:5173,http://127.0.0.1
DATABASE_URL=sqlite:///./predict-strike.db
REDIS_URL=redis://localhost:6379/0
NOTAM_SOURCE_URL=
# FAA NMS-API onboarding values. The backend uses the env selected by
# NOTAM_ENV and falls back to these legacy variables when scoped values are
# absent. Keep NOTAM_SOURCE_URL only for legacy/local compatibility.
NOTAM_ENV=production
NOTAM_API_BASE_URL=https://api-nms.aim.faa.gov/nmsapi/v1
NOTAM_AUTH_URL=https://api-nms.aim.faa.gov/v1/auth/token
NOTAM_CLIENT_ID=
NOTAM_CLIENT_SECRET=
NOTAM_CLASSIFICATION=
NOTAM_ACCOUNTABILITY=
NOTAM_LOCATION=
NOTAM_TEST_SOURCE_URL=
NOTAM_TEST_API_BASE_URL=https://api-staging.cgifederal-aim.com/nmsapi/v1
NOTAM_TEST_AUTH_URL=https://api-staging.cgifederal-aim.com/v1/auth/token
NOTAM_TEST_CLIENT_ID=
NOTAM_TEST_CLIENT_SECRET=
NOTAM_TEST_CLASSIFICATION=
NOTAM_TEST_ACCOUNTABILITY=
NOTAM_TEST_LOCATION=
NOTAM_PRODUCTION_SOURCE_URL=
NOTAM_PRODUCTION_API_BASE_URL=https://api-nms.aim.faa.gov/nmsapi/v1
NOTAM_PRODUCTION_AUTH_URL=https://api-nms.aim.faa.gov/v1/auth/token
NOTAM_PRODUCTION_CLIENT_ID=
NOTAM_PRODUCTION_CLIENT_SECRET=
NOTAM_PRODUCTION_CLASSIFICATION=
NOTAM_PRODUCTION_ACCOUNTABILITY=
NOTAM_PRODUCTION_LOCATION=
# Optional filters for the authenticated NOTAM collector.
NOTAM_RESPONSE_FORMAT=GEOJSON
NOTAM_DETAIL_FETCH_ENABLED=false
NOTAM_MAX_ITEMS=20
NOTAM_TIMEOUT_SECONDS=10
NOTAM_AI_API_URL=https://api.openai.com/v1/chat/completions
NOTAM_AI_API_KEY=
NOTAM_AI_MODEL=
NOTAM_AI_TIMEOUT_SECONDS=15
# Canonical news source for the GDELT slice: official GDELT DOC 2.0 article-list JSON endpoint.
# Example: https://api.gdeltproject.org/api/v2/doc/doc?query=(conflict%20OR%20missile)&mode=artlist&maxrecords=50&format=json
GDELT_SOURCE_URL=
GDELT_TIMEOUT_SECONDS=30
GDELT_AI_API_URL=https://api.openai.com/v1/chat/completions
GDELT_AI_API_KEY=
GDELT_AI_MODEL=
GDELT_AI_TIMEOUT_SECONDS=15
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com/
POLYMARKET_PIZZINT_BREAKING_URL=https://www.pizzint.watch/api/markets/breaking?window=6h&final_limit=20&format=ticker
PIZZA_INDEX_ENABLE_LIVE_PROVIDER=true
PIZZA_INDEX_DASHBOARD_URL=https://www.pizzint.watch/api/dashboard-data
PIZZA_INDEX_PROVIDER_TIMEOUT_SECONDS=8
SERPAPI_API_KEY=
SERPAPI_DAILY_LIMIT=4
OPENSKY_AI_API_URL=https://api.openai.com/v1/chat/completions
OPENSKY_AI_API_KEY=
OPENSKY_AI_MODEL=
OPENSKY_AI_TIMEOUT_SECONDS=15
