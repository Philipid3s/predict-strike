# Backend service environment variables.
# Copy to backend/.env and adjust for your chosen stack.

APP_ENV=development
APP_PORT=8000
API_BASE_PATH=/api
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost,http://127.0.0.1:5173,http://127.0.0.1
DATABASE_URL=sqlite:///./predict-strike.db
REDIS_URL=redis://localhost:6379/0
NOTAM_SOURCE_URL=
# Canonical news source for the GDELT slice: official GDELT DOC 2.0 article-list JSON endpoint.
# Example: https://api.gdeltproject.org/api/v2/doc/doc?query=(conflict%20OR%20missile)&mode=artlist&maxrecords=50&format=json
GDELT_SOURCE_URL=
GDELT_TIMEOUT_SECONDS=30
GDELT_AI_API_URL=https://api.openai.com/v1/chat/completions
GDELT_AI_API_KEY=
GDELT_AI_MODEL=
GDELT_AI_TIMEOUT_SECONDS=15
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com/
POLYMARKET_PIZZINT_BREAKING_URL=https://www.pizzint.watch/api/markets/breaking?window=6h&final_limit=20&format=ticker
PIZZA_INDEX_ENABLE_LIVE_PROVIDER=true
PIZZA_INDEX_DASHBOARD_URL=https://www.pizzint.watch/api/dashboard-data
PIZZA_INDEX_PROVIDER_TIMEOUT_SECONDS=8
SERPAPI_API_KEY=
SERPAPI_DAILY_LIMIT=4
OPENSKY_AI_API_URL=https://api.openai.com/v1/chat/completions
OPENSKY_AI_API_KEY=
OPENSKY_AI_MODEL=
OPENSKY_AI_TIMEOUT_SECONDS=15
