# Root-level environment variables shared by infrastructure or tooling.
# Copy to .env for local use.

PROJECT_NAME=predict-strike
ENVIRONMENT=development
FRONTEND_VITE_API_URL=/api

# Required for production docker-compose.yml when whole-site Basic Auth is enabled
# via the frontend reverse proxy. Do not commit real credentials.
FRONTEND_BASIC_AUTH_USERNAME=operator
FRONTEND_BASIC_AUTH_PASSWORD=change-me
